import WebSocket from 'ws';

export function verifyRoomIsLive(url, token, timeoutMs = 10000) {
  return new Promise((resolve, reject) => {
    // LiveKit signaling endpoint
    const wsUrl = `${url}/rtc?access_token=${token}&auto_subscribe=true&protocol=9`;

    const ws = new WebSocket(wsUrl);
    let isResolved = false;

    const timer = setTimeout(() => {
      if (!isResolved) {
        isResolved = true;
        ws.close();
        reject(new Error("Timeout: Room is not live or unreachable"));
      }
    }, timeoutMs);

    ws.on('open', () => {
      console.log("✅ WebSocket connection opened - Room is reachable");
    });

    ws.on('message', (data) => {
      if (!isResolved) {
        isResolved = true;
        clearTimeout(timer);
        console.log("✅ Received response from LiveKit - Room is LIVE");
        ws.close(1000);
        resolve({
          isLive: true,
          message: "Room is live and accepting connections",
        });
      }
    });

    ws.on('error', (err) => {
      if (!isResolved) {
        isResolved = true;
        clearTimeout(timer);
        reject(new Error(`Room is NOT live: ${err.message}`));
      }
    });

    ws.on('close', (code, reason) => {
      clearTimeout(timer);
      if (!isResolved) {
        isResolved = true;
        if (code === 1000) {
          resolve({ isLive: true, message: "Room connection verified" });
        } else {
          reject(
            new Error(`Room closed unexpectedly - Code: ${code}, Reason: ${reason}`)
          );
        }
      }
    });
  });
}


