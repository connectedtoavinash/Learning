## 5. Deployment Diagram

```plantuml
@startuml
title Deployment Diagram

skinparam backgroundColor #FEFEFE

cloud "Internet" as internet {
    actor "Students &\nTeachers" as users
}

node "AWS / Cloud" {

    rectangle "NLB\n(Layer 4 TCP)" as nlb #LightBlue

    node "Kubernetes Cluster" as k8s {

        node "Pod 1" as p1 #LightGreen {
            artifact "device-control\n(Java/Spring)" as dc1
        }

        node "Pod 2" as p2 #LightGreen {
            artifact "device-control\n(Java/Spring)" as dc2
        }

        node "Pod 3" as p3 #LightGreen {
            artifact "device-control\n(Java/Spring)" as dc3
        }

        node "Class-Control Pod" as ccp #Orange {
            artifact "class-control\n(Java/Spring)" as cc
        }
    }

    node "Redis Cluster" as redisNode #Salmon {
        database "Redis" as redis {
            collections "CLASSROOM_EVENTS\n(Stream)" as stream
        }
    }
}

users -down-> nlb : WSS (443)
nlb -down-> dc1 : WS
nlb -down-> dc2 : WS
nlb -down-> dc3 : WS

cc -right-> stream : XADD

stream -up-> dc1 : XREAD
stream -up-> dc2 : XREAD
stream -up-> dc3 : XREAD

@enduml
```

