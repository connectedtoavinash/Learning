## 3. Component Diagram

```plantuml
@startuml
title Component Diagram - Device Control Pod

skinparam backgroundColor #FEFEFE
skinparam componentStyle rectangle

package "Device-Control Pod" as pod #LightGreen {

    component "WebSocket\nEndpoint" as wsEndpoint {
        portin "WS Connection\n(from NLB)" as wsIn
    }

    component "Session\nManager" as sessionMgr {
        database "activeSessions\nMap<String,\nWebSocketSession>" as sessMap
    }

    component "Redis Stream\nConsumer" as redisConsumer {
        portin "XREAD from\nCLASSROOM_EVENTS" as redisIn
    }

    component "Message\nDispatcher" as dispatcher

    wsEndpoint -down-> sessionMgr : onConnect()\nregister session
    wsEndpoint -down-> sessionMgr : onDisconnect()\nremove session

    redisConsumer -right-> dispatcher : parsed event\nwith studentIds[]

    dispatcher -up-> sessionMgr : lookup each\nstudentId

    dispatcher -left-> wsEndpoint : send WS message\n(if session exists)
}

@enduml
```

