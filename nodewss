// 5.1 Verify WebSocket URL is live using browser context
const page = await (await request.newContext()).newPage(); // or use an existing page
const isLive = await page.evaluate(({ url, token }) => {
  return new Promise((resolve) => {
    const ws = new WebSocket(`${url}?access_token=${token}`);
    const timer = setTimeout(() => {
      ws.close();
      resolve(false);
    }, 5000);

    ws.onopen = () => {
      clearTimeout(timer);
      ws.close();
      resolve(true);
    };

    ws.onerror = () => {
      clearTimeout(timer);
      resolve(false);
    };
  });
}, { url: startClassroomResponse.url, token: startClassroomResponse.token });

expect(isLive).toBe(true);



